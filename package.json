{
  "name": "play-it-up",
  "productName": "Play It Up",
  "version": "0.2.5",
  "description": "Cross-platform IPTV desktop app for Xtream Codes and M3U playlists (HLS + optional mpv).",
  "main": "dist-electron/main.js",
  "type": "module",
  "author": {
    "name": "Play It Up"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json && tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis --publish never",
    "dist:linux": "npm run build && electron-builder --linux AppImage --publish never",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "hls.js": "^1.6.16",
    "iso8601-duration": "^2.1.2",
    "lucide-react": "^0.474.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^9.18.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "tar": "^7.5.13"
  },
  "build": {
    "appId": "com.playitup.app",
    "productName": "Play It Up",
    "icon": "Assets/Play-it-uplogo.png",
    "asar": true,
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "Assets/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/mpv/${platform}/${arch}",
        "to": "mpv",
        "filter": [
          "**/*",
          "!**/.gitkeep"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.video"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "AudioVideo",
      "artifactName": "${name}-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "BilodeauIsADev",
      "repo": "Play-it-up"
    }
  }
}
